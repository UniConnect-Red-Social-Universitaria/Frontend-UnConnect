{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",             
    "moduleResolution": "NodeNext",  
    "composite": true,                
    "declaration": true,
    "emitDeclarationOnly": false,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}