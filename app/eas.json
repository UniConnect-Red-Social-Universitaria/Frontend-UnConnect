{
	"cli": {
		"version": ">= 16.17.4",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal",
			"env": {
				"EXPO_PUBLIC_API_URL": "https://uniconnect-backend.fly.dev",
				"EXPO_PUBLIC_ALLOWED_DOMAIN": "ucaldas.edu.co"
			}
		},
		"preview": {
			"distribution": "internal",
			"android": {
				"buildType": "apk"
			},
			"env": {
				"EXPO_PUBLIC_API_URL": "https://uniconnect-backend.fly.dev",
				"EXPO_PUBLIC_ALLOWED_DOMAIN": "ucaldas.edu.co"
			}
		},
		"production": {
			"autoIncrement": true,
			"android": {
				"buildType": "app-bundle"
			},
			"env": {
				"EXPO_PUBLIC_API_URL": "https://uniconnect-backend.fly.dev",
				"EXPO_PUBLIC_ALLOWED_DOMAIN": "ucaldas.edu.co"
			}
		}
	},
	"submit": {
		"production": {}
	}
}
